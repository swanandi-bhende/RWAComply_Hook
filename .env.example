# Copy this file to .env and replace placeholders after each fresh deployment.

# Deployer private key (anvil default shown as placeholder format)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# From script/DeployCore.s.sol
POOL_MANAGER=0xPOOL_MANAGER_ADDRESS

# From script/DeployHook.s.sol (or PoolSetup.s.sol if that flow is used)
HOOK_ADDRESS=0xHOOK_ADDRESS

# ERC20 token contract addresses (must never be POOL_MANAGER)
TOKEN_A=0xTOKEN_A_ERC20_ADDRESS
TOKEN_B=0xTOKEN_B_ERC20_ADDRESS
